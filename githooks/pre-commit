#!/bin/sh
# A Team Website carousel manifest hook

set -e

ROOT=$(git rev-parse --show-toplevel)
cd "$ROOT"

if ! command -v node >/dev/null 2>&1; then
  printf >&2 "node is required to update carousel manifests before commit.\n"
  exit 1
fi

MANIFESTS=$(find image -name manifest.json -type f 2>/dev/null || true)

if [ -z "$MANIFESTS" ]; then
  exit 0
fi

printf "%s\n" "$MANIFESTS" | while IFS= read -r manifest; do
  folder=$(dirname "$manifest")
  node scripts/update-carousel-manifest.js "$folder"
  git add "$manifest"
done
